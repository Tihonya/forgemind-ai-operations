# ForgeMind AI Operations - Environment Configuration
# Copy this file to .env and replace placeholder values

# ============================================================================
# Database Configuration
# ============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=forgemind
POSTGRES_USER=forgemind
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_in_production
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# ============================================================================
# Backend Configuration
# ============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
BACKEND_LOG_LEVEL=INFO
SECRET_KEY=changeme_generate_32_random_bytes
API_V1_PREFIX=/api/v1

# ============================================================================
# Frontend Configuration
# ============================================================================
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws

# ============================================================================
# AI/LLM Configuration
# ============================================================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3

# ============================================================================
# Application Settings
# ============================================================================
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_PER_MINUTE=60
AI_RATE_LIMIT_PER_MINUTE=10

# ============================================================================
# Caddy Configuration
# ============================================================================
CADDY_DOMAIN=localhost
CADDY_EMAIL=admin@example.com

# ============================================================================
# Demo Data
# ============================================================================
SEED_GOLDEN_DATASET=true
DEMO_RESET_ALLOWED=true
